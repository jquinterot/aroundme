FROM node:20-alpine AS base

RUN apk add --no-cache libc6-compat

FROM base AS deps
WORKDIR /app

COPY package.json package-lock.json* ./
COPY prisma/schema.prisma ./prisma/schema.prisma
RUN npm ci

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY e2e ./e2e
COPY playwright.api.config.ts ./playwright.api.config.ts
COPY . .

ENV NEXT_TELEMETRY_DISABLED 1
ENV PRISMA_GENERATE_DATASOURCE_URL "postgresql://user:pass@localhost:5432/aroundme_test"

RUN npx prisma generate
RUN npm run build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV test
ENV NEXT_TELEMETRY_DISABLED 1
ENV DATABASE_URL="postgresql://postgres:postgres@db:5432/aroundme_test?schema=public"

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/prisma.config.ts ./prisma.config.ts
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/playwright.api.config.ts ./playwright.api.config.ts
COPY --from=builder /app/src ./src
COPY --from=builder /app/e2e ./e2e

RUN mkdir -p /app/test-results /app/playwright-report
RUN chown -R nextjs:nodejs /app

USER nextjs

ENV PORT 3000
ENV HOSTNAME "0.0.0.0"

CMD ["sh", "-c", "npm run db:reset && node server.js & sleep 10 && npx playwright test --config=playwright.api.config.ts --project=api"]
