generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model City {
  id          String   @id @default(cuid())
  name        String
  country     String
  slug        String   @unique
  lat         Float
  lng         Float
  zoom        Float    @default(12)
  timezone    String   @default("America/Bogota")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  events      Event[]
  places      Place[]
  users       User[]
  activities  Activity[]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          String   @default("user")
  cityId        String?
  isVerified    Boolean  @default(false)
  avatarUrl     String?
  bio           String?
  website       String?
  instagram     String?
  followerCount Int      @default(0)
  followingCount Int     @default(0)
  eventCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  city          City?    @relation(fields: [cityId], references: [id])
  events        Event[]
  reviews       Review[]
  ownedPlaces   Place[]
  saves         Save[]
  rsvps         RSVP[]
  notifications Notification[]
  sessions      Session[]
  viewHistory   ViewHistory[]
  pushSubscriptions PushSubscription[]
  orders        Order[]
  followers     Follow[] @relation("following")
  following     Follow[] @relation("follower")
  userActivities UserActivity[]
  activities    Activity[]
  sentEmails    EmailLog[]
  waitlists     Waitlist[]
  checkIns      CheckIn[]
  recommendationsReceived Recommendation[] @relation("recommendedTo")
  bookings      ActivityBooking[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String
  status        String   @default("pending")
  cityId        String
  venueName     String
  venueAddress  String
  venueLat      Float
  venueLng      Float
  dateStart     DateTime
  dateEnd       DateTime?
  priceMin      Float?
  priceMax      Float?
  currency      String   @default("COP")
  isFree        Boolean  @default(true)
  imageUrl      String?
  tags          String   @default("")
  userId        String?
  viewCount     Int      @default(0)
  saveCount     Int      @default(0)
  isFeatured    Boolean  @default(false)
  featuredUntil DateTime?
  featuredTier  String   @default("none")
  isPrivate     Boolean  @default(false)
  maxAttendees  Int?
  currentAttendees Int   @default(0)
  seriesId      String?
  series        EventSeries? @relation(fields: [seriesId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  city          City     @relation(fields: [cityId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])
  saves         Save[]
  rsvps         RSVP[]
  ticketTypes   TicketType[]
  waitlist      Waitlist[]
  checkIns      CheckIn[]
  userActivities UserActivity[]
}

model EventSeries {
  id            String   @id @default(cuid())
  name          String
  description   String?
  frequency     String   // daily, weekly, biweekly, monthly
  interval      Int      @default(1)
  dayOfWeek     Int?     // 0-6 for weekly
  dayOfMonth    Int?     // 1-31 for monthly
  startDate     DateTime
  endDate       DateTime?
  occurrences   Int?     // number of times to repeat
  parentEventId String?  // template event
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  events        Event[]
}

model Place {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  cityId      String
  address     String
  lat         Float
  lng         Float
  imageUrl    String?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  priceRange  String?
  isVerified  Boolean  @default(false)
  isClaimed   Boolean  @default(false)
  ownerId     String?
  features    String   @default("")
  tags        String   @default("")
  contactPhone String?
  contactWebsite String?
  contactInstagram String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  city        City     @relation(fields: [cityId], references: [id])
  owner       User?    @relation(fields: [ownerId], references: [id])
  reviews     Review[]
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  comment     String
  userId      String
  placeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id])
  place       Place    @relation(fields: [placeId], references: [id])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model RSVP {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  status    String   @default("going") // going, interested, maybe
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // event_reminder, new_rsvp, new_review, event_update, venue_update
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  data      String?  // JSON data for additional info
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model ViewHistory {
  id        String   @id @default(cuid())
  userId    String
  type      String   // event, place
  itemId    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, type])
}

model AdminReport {
  id          String   @id @default(cuid())
  reporterId  String?
  type        String   // event, place, review, user
  itemId      String
  reason      String
  description String?
  status      String   @default("pending") // pending, reviewed, resolved, dismissed
  adminId     String?
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([type])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      String   // JSON { p256dh, auth }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Float
  quantity    Int
  sold        Int      @default(0)
  maxPerUser  Int      @default(10)
  saleStart   DateTime?
  saleEnd     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([eventId])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  status          String   @default("pending") // pending, completed, cancelled, refunded
  total           Float
  currency        String   @default("COP")
  stripeSessionId String?  @unique
  stripePaymentId String?
  email           String
  name            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  priceAtTime  Float
  createdAt    DateTime   @default(now())
  
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserActivity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // created_event, rsvp, review, follow, save, check_in
  eventId     String?
  placeId     String?
  targetUserId String?
  metadata    String?  // JSON data
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Waitlist {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  position    Int
  notifyAt    Int?     // notify when X spots available
  status      String   @default("waiting") // waiting, notified, converted, expired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, userId])
  @@index([eventId, position])
}

model CheckIn {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  ticketTypeId String?
  checkedInAt DateTime @default(now())
  checkInMethod String // qr_code, manual, api
  createdAt   DateTime @default(now())
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, userId])
  @@index([eventId])
}

model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  eventId     String?
  placeId     String?
  score       Float    @default(0)
  reason      String?
  isViewed    Boolean  @default(false)
  isClicked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation("recommendedTo", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isViewed])
  @@index([userId, createdAt])
}

model EmailLog {
  id          String   @id @default(cuid())
  userId      String
  type        String   // digest, reminder, promotion, welcome
  subject     String
  content     String
  sentAt      DateTime @default(now())
  openedAt    DateTime?
  clickedAt   DateTime?
  bouncedAt   DateTime?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, sentAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // digest, reminder, promotion, welcome, event_update
  subject     String
  content     String   // HTML template with placeholders
  variables   String   // JSON array of variable names
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // class, tour, entertainment, experience, wellness
  subcategory String?  // salsa, yoga, coffee-tour, etc.
  cityId      String
  providerName String  // Person or business offering the activity
  providerContact String? // Email or phone
  schedule    String   // Human readable: "Every Tuesday 7pm", "Fridays 9pm"
  scheduleDays String? // JSON: ["tuesday", "friday"]
  scheduleTime String? // Time: "19:00"
  duration    String?  // "2 hours", "Full day"
  capacity    Int?
  price       Float    @default(0)
  currency    String   @default("COP")
  isFree      Boolean  @default(false)
  imageUrl    String?
  includes    String?  // JSON array: ["Transport", "Equipment", "Coffee tasting"]
  skillLevel  String?  // beginner, intermediate, all_levels
  status      String   @default("active") // active, paused, cancelled
  userId      String?
  viewCount   Int      @default(0)
  bookingCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  city        City     @relation(fields: [cityId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  bookings    ActivityBooking[]

  @@index([cityId, status])
  @@index([category])
}

model ActivityBooking {
  id            String   @id @default(cuid())
  activityId    String
  userId        String?
  guestName     String
  guestEmail    String
  guestPhone    String?
  tickets       Int      @default(1)
  total         Float
  status        String   @default("pending") // pending, confirmed, cancelled
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  activity      Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([activityId])
}
