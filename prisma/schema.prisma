generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model City {
  id          String   @id @default(cuid())
  name        String
  country     String
  slug        String   @unique
  lat         Float
  lng         Float
  zoom        Float    @default(12)
  timezone    String   @default("America/Bogota")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  events      Event[]
  places      Place[]
  users       User[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        String   @default("user")
  cityId      String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  city        City?    @relation(fields: [cityId], references: [id])
  events      Event[]
  reviews     Review[]
  ownedPlaces Place[]
  saves       Save[]
  rsvps       RSVP[]
  notifications Notification[]
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  status      String   @default("pending")
  cityId      String
  venueName   String
  venueAddress String
  venueLat    Float
  venueLng    Float
  dateStart   DateTime
  dateEnd     DateTime?
  priceMin    Float?
  priceMax    Float?
  currency    String   @default("COP")
  isFree      Boolean  @default(true)
  imageUrl    String?
  tags        String   @default("")
  userId      String?
  viewCount   Int      @default(0)
  saveCount   Int      @default(0)
  isFeatured  Boolean  @default(false)
  featuredUntil DateTime?
  featuredTier String   @default("none") // none, basic, premium
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  city        City     @relation(fields: [cityId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  saves       Save[]
  rsvps       RSVP[]
}

model Place {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  cityId      String
  address     String
  lat         Float
  lng         Float
  imageUrl    String?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  priceRange  String?
  isVerified  Boolean  @default(false)
  isClaimed   Boolean  @default(false)
  ownerId     String?
  features    String   @default("")
  tags        String   @default("")
  contactPhone String?
  contactWebsite String?
  contactInstagram String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  city        City     @relation(fields: [cityId], references: [id])
  owner       User?    @relation(fields: [ownerId], references: [id])
  reviews     Review[]
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  comment     String
  userId      String
  placeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id])
  place       Place    @relation(fields: [placeId], references: [id])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model RSVP {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  status    String   @default("going") // going, interested, maybe
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // event_reminder, new_rsvp, new_review, event_update, venue_update
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  data      String?  // JSON data for additional info
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}
