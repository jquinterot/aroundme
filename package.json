{
  "name": "aroundme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e:ui": "npx playwright test e2e/ui --project=chromium",
    "test:e2e:ui:headed": "npx playwright test e2e/ui --project=chromium --headed",
    "test:e2e:ui:debug": "npx playwright test e2e/ui --project=chromium --debug",
    "test:e2e:api": "npx playwright test e2e/api --project=api",
    "test:e2e:api:headed": "npx playwright test e2e/api --project=api --headed",
    "test:e2e:api:debug": "npx playwright test e2e/api --project=api --debug",
    "test:e2e:all": "npx playwright test e2e",
    "test:e2e:report": "npx playwright show-report",
    "api:test": "npx playwright test e2e/api --project=api",
    "ui:test": "npx playwright test e2e/ui --project=chromium",
    "db:setup": "npx prisma generate && npx prisma db push --accept-data-loss",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:reset": "npx prisma db push --force-reset --accept-data-loss && npx tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.10",
    "@stripe/stripe-js": "^8.11.0",
    "@tanstack/react-query": "^4.36.1",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox-gl": "^3.4.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cloudinary": "^2.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "prisma": "^7.5.0",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "react-leaflet": "^5.0.0",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
